# Database
DATABASE_URL="file:./dev.db"

# Redis (optional - for future features)
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# AI Provider: "ollama" (default and recommended) or "openrouter"
AI_PROVIDER=ollama

# Ollama Configuration (when AI_PROVIDER=ollama)
# Install from https://ollama.ai
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen3:0.6b"
# Requires Ollama v0.13.5+ for function calling support
OLLAMA_FUNCTION_MODEL="functiongemma:latest"

# OpenRouter Configuration (when AI_PROVIDER=openrouter) - https://openrouter.ai
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL="sourceful/riverflow-v2-fast"

# Server Configuration
PORT=8000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# Telegram Notifications (optional)
# Get bot token from https://t.me/botfather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Your Telegram chat ID (number, can be negative for groups)
TELEGRAM_CHAT_ID=-1234567890

# Tavily API (optional - for Architect agent product research)
# Get key from https://tavily.com
TAVILY_API_KEY=tvly-dev-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gmail SMTP (optional - for sending customer communication)
# Use Gmail app password (not your main password)
# https://support.google.com/accounts/answer/185833
GMAIL_EMAIL=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Pexels API (optional - for product images)
# Get key from https://www.pexels.com/api/
PEXELS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx